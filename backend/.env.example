# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-use-a-long-random-string
DJANGO_DEBUG=True
# Comma-separated list of allowed hostnames (leave empty for localhost dev)
DJANGO_ALLOWED_HOSTS=

# When DJANGO_DEBUG=False but you run `manage.py runserver` on your PC with Vite (localhost:5173),
# set to 1 so CORS + ALLOWED_HOSTS include local Vite origins and 127.0.0.1/localhost. Omit on Render.
# Also disables SECURE_SSL_REDIRECT for plain HTTP runserver (avoids ERR_SSL_PROTOCOL_ERROR).
# DJANGO_APPEND_LOCAL_VITE_CORS=1
# When set with DEBUG=False, Django also serves /media/ locally (avatars & uploads); omit on Render.

# Local SQLite (no Postgres/Neon). Set to 1 for quick UI testing; use Postgres for production-like dev.
# DJANGO_USE_SQLITE=1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Do not wrap values in extra quotes (wrong: DB_PASSWORD='npg_abc' — use DB_PASSWORD=npg_abc).
# Neon “Connection details” use PG* names — map to Django like this:
#   PGDATABASE → DB_NAME    PGUSER → DB_USER    PGPASSWORD → DB_PASSWORD
#   PGHOST → DB_HOST        PGPORT → DB_PORT    PGSSLMODE → DB_SSLMODE
#   PGCHANNELBINDING → DB_CHANNEL_BINDING (optional; leave unset if connect fails)
DB_NAME=traffic_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer
# DB_CHANNEL_BINDING=require

# ── JWT token lifetimes ────────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MIN=30
JWT_REFRESH_LIFETIME_DAYS=7

# ── Email (Gmail SMTP) — see traffic_system/settings_email.py for full steps ──
#
# IMPORTANT — Gmail App Password (never use your normal Gmail password):
#   Step 1: Google Account → Security → Enable 2-Step Verification
#   Step 2: Google Account → Security → App Passwords
#   Step 3: Select "Mail" and "Other (custom name)" → name it "CamTraffic AI"
#   Step 4: Google generates a 16-character App Password (e.g. abcd efgh ijkl mnop)
#   Step 5: Copy into EMAIL_HOST_PASSWORD below (spaces are stripped automatically)
#
# Console dev: OTP prints in the Django terminal only.
# Real inbox: set EMAIL_HOST_USER + EMAIL_HOST_PASSWORD (and optional DEFAULT_FROM_EMAIL).
# If HOST+USER+PASS are set, SMTP is used even when EMAIL_BACKEND is still "console".

# Public URL of the React app (no trailing slash). Used in password-reset emails so the
# “Reset Password” button opens /reset-password?token=… on the correct host.
# Example dev: PUBLIC_APP_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
# How long the reset link in email remains valid (minutes).
PASSWORD_RESET_LINK_TTL_MINUTES=60

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=camtraffic@gmail.com
EMAIL_HOST_PASSWORD=abcdefghijklmnop
DEFAULT_FROM_EMAIL=CamTraffic AI <camtraffic@gmail.com>
EMAIL_SUBJECT_PREFIX=[CamTraffic]
EMAIL_TIMEOUT=10

# Shown in password-changed and security emails (mailto link)
SUPPORT_CONTACT_EMAIL=camtraffic@gmail.com

# ── Resend (recommended) ───────────────────────────────────────────────────────
# Set these two to send OTP emails via Resend (no Gmail App Password needed).
# RESEND_FROM: full address. Bare domain (e.g. yourdomain.com) becomes noreply@yourdomain.com.
# You must verify that domain in the Resend dashboard or API returns 403.
# For quick dev tests, try RESEND_FROM=onboarding@resend.dev (recipient limits apply — see Resend docs).
RESEND_API_KEY=
RESEND_FROM=CamTraffic AI <no-reply@yourdomain.com>

# ── CORS (production only; dev origins are added automatically when DEBUG=True) ──
CORS_ALLOWED_ORIGINS=

# ── Social OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
