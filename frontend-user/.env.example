# ── API ────────────────────────────────────────────────────────────────────────
# Leave empty to use the Vite proxy (recommended for dev). Set to a full URL
# (e.g. https://api.example.com/api/) only for standalone/production builds.
VITE_API_URL=

# ── Portal surface ─────────────────────────────────────────────────────────────
# Forces this app to behave as the user portal (instead of port/hostname heuristics).
VITE_PORTAL_SURFACE=user

# ── Admin portal detection ─────────────────────────────────────────────────────
# The dev:admin script runs on port 5174; this tells portal.js to treat that
# port as the admin portal so role-based routing works correctly.
VITE_ADMIN_PORT=5174
VITE_ADMIN_HOSTNAME=admin.localhost

# ── Social OAuth (match the values in backend/.env) ───────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
VITE_MICROSOFT_CLIENT_ID=
